# Turso libSQL 데이터베이스 (필수)
# `turso db show <db-name> --url` 로 얻은 libsql://... URL
TURSO_DATABASE_URL=libsql://au-law-mcp-<username>.turso.io
# `turso db tokens create <db-name>` 로 얻은 인증 토큰
TURSO_AUTH_TOKEN=eyJhbGciOi...

# HuggingFace (선택: 다운로드 속도 향상 및 레이트 리밋 완화)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxx

# 빌드 파이프라인 중간 산출물 저장 경로 (로컬 작업)
# 기본값: ./data
BUILD_DATA_DIR=./data

# 배치 크기 (Turso insert 성능에 영향). 기본 500.
BULK_INSERT_BATCH_SIZE=500

# MCP 서버 관련 (Phase 2부터 사용)
MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_LEVEL=INFO
